{
  "name": "star-sweeper",
  "version": "1.0.0",
  "description": "CLI tool to unstar all starred GitHub repositories for the authenticated user",
  "module": "index.ts",
  "type": "module",
  "bin": {
    "star-sweeper": "./index.ts"
  },
  "scripts": {
    "start": "bun run index.ts",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit"
  },
  "private": true,
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.6.0",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.56.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "octokit": "^5.0.5"
  }
}
